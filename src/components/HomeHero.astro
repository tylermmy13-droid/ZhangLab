<!-- ===== 首页首屏与滚动宣传图 ===== -->
<section class="home-hero" data-home-hero>
  <div class="home-hero-sticky">
    <div class="home-hero-content">
      <h1 class="home-hero-title" data-en="Cardiovascular research,&lt;br /&gt;grounded in clinical questions." data-zh="从临床问题出发的&lt;br /&gt;心血管医学研究">Cardiovascular research,<br />grounded in clinical questions.</h1>
      <p class="home-hero-summary" data-en="Zhang Lab studies vascular injury and repair, myocardial remodeling, multi-organ interactions, wearable monitoring, and data science for cardiovascular medicine. We connect clinical observations, experimental models, and reproducible data analysis to address questions in prevention, diagnosis, and treatment." data-zh="张力课题组围绕血管损伤与修复、心肌重构、多器官互作、可穿戴监测及心血管医学数据科学开展研究。我们结合临床观察、实验模型与可重复的数据分析，探讨疾病预防、诊断与治疗中的问题。">Zhang Lab studies vascular injury and repair, myocardial remodeling, multi-organ interactions, wearable monitoring, and data science for cardiovascular medicine. We connect clinical observations, experimental models, and reproducible data analysis to address questions in prevention, diagnosis, and treatment.</p>
    </div>

    <div class="home-hero-media" data-home-hero-media>
      <img src="/assets/home/cardiovascular-figure.jpg" alt="Fluorescence microscopy image" />
      <div class="home-hero-media-shade" aria-hidden="true"></div>
    </div>
  </div>
</section>

<script>
  const hero = document.querySelector<HTMLElement>('[data-home-hero]');
  const header = document.querySelector<HTMLElement>('[data-scroll-header]');

  if (hero) {
    let frame = 0;

    const updateHero = () => {
      frame = 0;
      const viewportHeight = window.innerHeight;
      const sceneLength = Math.max(hero.offsetHeight - viewportHeight, 1);
      const rawProgress = Math.min(Math.max(-hero.getBoundingClientRect().top / sceneLength, 0), 1);
      const progress = Math.min(rawProgress / 0.68, 1);
      const eased = progress * progress * (3 - 2 * progress);
      const startInset = Math.min(48, Math.max(20, window.innerWidth * 0.025));
      const startTop = viewportHeight - Math.max(180, Math.min(300, viewportHeight * 0.24));
      const startHeight = Math.max(viewportHeight * 0.72, 430);

      hero.style.setProperty('--hero-media-top', `${startTop * (1 - eased)}px`);
      hero.style.setProperty('--hero-media-inset', `${startInset * (1 - eased)}px`);
      hero.style.setProperty('--hero-media-height', `${startHeight + (viewportHeight - startHeight) * eased}px`);
      hero.style.setProperty('--hero-media-radius', `${Math.max(0, 38 * (1 - eased))}px`);
      hero.style.setProperty('--hero-copy-opacity', `${Math.max(0, 1 - rawProgress * 2.8)}`);
      hero.style.setProperty('--hero-media-shade', `${Math.max(0, 0.86 - progress * 1.35)}`);
      header?.classList.toggle('on-dark', rawProgress > 0.46 && rawProgress < 0.96);
      header?.classList.toggle('on-light', !(rawProgress > 0.46 && rawProgress < 0.96));
    };

    const requestUpdate = () => {
      if (!frame) frame = window.requestAnimationFrame(updateHero);
    };

    updateHero();
    window.addEventListener('scroll', requestUpdate, { passive: true });
    window.addEventListener('resize', requestUpdate);
  }
</script>

<style>
