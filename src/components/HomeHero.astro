    line-height: 1.25;
    letter-spacing: -0.025em;
  }

  :global(html[lang="zh-CN"]) .home-hero-summary {
    line-height: 1.7;
    max-width: 540px;
  }

  /* Chinese title occupies two taller lines; lift both columns together. */
  :global(html[lang="zh-CN"]) .home-hero-content {
    transform: translateY(clamp(-80px, -5vh, -40px));
  }

  .home-hero-summary {
    align-self: end;
    max-width: 510px;
    margin: 0;
    color: var(--ink);
    font-family: var(--font-body);
    font-size: clamp(18px, 1.55vw, 25px);
    font-weight: 500;
    line-height: 1.55;
    letter-spacing: -0.01em;
  }

  .home-hero-media {
    position: absolute;
    z-index: 3;
    top: var(--hero-media-top, calc(100dvh - 112px));
    right: var(--hero-media-inset, 48px);
    left: var(--hero-media-inset, 48px);
    height: var(--hero-media-height, 72dvh);
    overflow: hidden;
    border-radius: var(--hero-media-radius, 38px);
    background: #050505;
    will-change: top, left, right, height, border-radius;
  }

  .home-hero-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.72) brightness(0.88);
  }

  .home-hero-media-shade {
    position: absolute;
