    height: 100%;
    margin: 0 auto;
    padding: clamp(176px, 22vh, 260px) 0 clamp(250px, 29vh, 360px);
    opacity: var(--hero-copy-opacity, 1);
    transition: opacity 80ms linear;
  }

  .home-hero-title {
    align-self: end;
    max-width: 950px;
    margin: 0;
    color: var(--ink);
    font-family: var(--font-title);
    font-size: clamp(48px, 6.2vw, 104px);
    font-weight: 400;
