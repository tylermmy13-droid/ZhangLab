---
const { item } = Astro.props;
const tag = item.data.tags?.[0] ?? item.data.venue;
const href = `/publications/${item.id}/`;
const searchText = [
  item.data.title,
  item.data.description,
  item.data.venue,
  ...item.data.tags,
  ...(item.data.authors ?? [])
].join(' ').toLowerCase();
const filterText = [item.data.venue, ...item.data.tags].join('|').toLowerCase();
---
<a class="card" href={href} data-publication-card data-search={searchText} data-filters={filterText}>
  <span class="card-media">
    <img class="card-image" src={item.data.image} alt="" loading="lazy" />
  </span>
  <span class="tag-pill">{tag}</span>
  <h3>{item.data.title}</h3>
  <p>{item.data.description}</p>
  <span class="card-meta">{item.data.venue}</span>
</a>
