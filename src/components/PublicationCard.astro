---
const { item } = Astro.props;
const pubDate = item.data.pubDate.toISOString().split('T')[0];
const paperUrl = item.data.paperUrl;
const Tag = paperUrl ? 'a' : 'div';
const attrs: Record<string, any> = { class: 'card publication-card' };
if (paperUrl) {
  attrs.href = paperUrl;
  attrs.target = '_blank';
  attrs.rel = 'noreferrer';
}
---
<Tag {...attrs}>
  <span class="card-media">
    <img class="card-image" src={item.data.image} alt="" loading="lazy" />
  </span>
  <div class="publication-card-body">
    <span class="tag-pill">{pubDate}</span>
    <h3 class="publication-card-title">{item.data.title}</h3>
    <p>{item.data.description}</p>
    <span class="card-meta">{item.data.venue}</span>
  </div>
</Tag>

<style>
  .publication-card {
    text-decoration: none;
    display: block;
    border-radius: 14px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    transition: all 0.3s ease;
    cursor: pointer;
  }
  .publication-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(217, 119, 87, 0.3);
    box-shadow: 0 8px 32px rgba(217, 119, 87, 0.08);
    transform: translateY(-3px);
  }

  /* Image spans full width, body has padding */
  .publication-card :global(.card-media) {
    margin: 0;
  }
  .publication-card :global(.card-image) {
    transition: transform 0.4s ease;
  }
  .publication-card:hover :global(.card-image) {
    transform: scale(1.07);
  }

  .publication-card-body {
    padding: 20px 22px 24px;
  }

  .publication-card :global(h3) {
    font-family: "DM Serif Display", "Noto Serif SC", Georgia, "Times New Roman", serif;
    font-weight: 400;
    font-size: clamp(17px, 1.4vw, 21px);
    line-height: 1.35;
    letter-spacing: -0.01em;
    color: #faf9f5;
    margin: 0 0 10px;
  }
  .publication-card :global(.tag-pill) {
    background: rgba(217, 119, 87, 0.12);
    color: #d97757;
    border: 1px solid rgba(217, 119, 87, 0.15);
    margin: 0 0 14px;
  }
  .publication-card :global(.card-meta) {
    color: rgba(255, 255, 255, 0.35);
    font-size: 12px;
  }
  .publication-card :global(p) {
    color: rgba(255, 255, 255, 0.55);
    font-size: 14px;
    line-height: 1.55;
    margin: 0 0 10px;
  }
</style>
