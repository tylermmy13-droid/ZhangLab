---
import type { StudentMember } from '../data/students';

const { student, accent } = Astro.props as {
  student: StudentMember;
  accent: string;
};

const initial = student.nameZh.charAt(0);
const enName = student.name.split('/')[1]?.trim() || '';

const typeLabels: Record<string, { en: string; zh: string }> = {
  'phd':                { en: 'Ph.D.', zh: '博士研究生' },
  'academic-master':    { en: 'M.A.Sc.', zh: '学术型硕士' },
  'professional-master':{ en: 'M.Eng.', zh: '专业型硕士' },
};
const roleLabel = typeLabels[student.type] ?? { en: '', zh: '' };
---
<!-- ===== 学生卡片组件 ===== -->
<div class="student-card" style={`--card-accent: ${accent}`}>
  <div class="student-card-avatar">
    <span class="student-card-initial">{initial}</span>
  </div>
  <div class="student-card-info">
    <p class="student-card-name">{student.nameZh}</p>
    <p class="student-card-name-en">{enName}</p>
    <span class="student-card-role" style={`background: ${accent}18`} data-en={roleLabel.en} data-zh={roleLabel.zh}>
      {roleLabel.zh}
    </span>
    <p class="student-card-enrollment" data-en={`Enrolled ${student.enrollmentYear}`} data-zh={`${student.enrollmentYear}级`}>
      {student.enrollmentYear}级
    </p>
  </div>
</div>

<style>
  .student-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    box-sizing: border-box;
    border-radius: 14px;
    overflow: hidden;
    background: #e4dbcd;
    text-decoration: none;
    transition: all 0.3s ease;
    flex-shrink: 0;
    cursor: default;
  }
  .student-card:hover {
    background: #f4e5c7;
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(20, 20, 19, 0.08);
  }
  .student-card-avatar {
    width: 100%;
    aspect-ratio: 1 / 0.72;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #e8e6dc;
  }
  .student-card-initial {
    font-size: 34px;
    font-weight: 600;
    color: rgba(20, 20, 19, 0.15);
    font-family: "Inter", sans-serif;
    user-select: none;
  }
  .student-card-info {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 12px 10px 16px;
    gap: 4px;
    width: 100%;
  }
  .student-card-name {
    margin: 0;
    color: #141413;
    font-weight: 600;
    font-size: 17px;
    line-height: 1.3;
  }
  .student-card-name-en {
    margin: 0;
    color: #141413;
    font-size: 13px;
    font-weight: 400;
  }
  .student-card-role {
    display: inline-block;
    margin-top: 4px;
    padding: 3px 12px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: #141413 !important;
  }
  .student-card-enrollment {
    margin: 2px 0 0;
    color: #141413;
    font-size: 11px;
  }
</style>
