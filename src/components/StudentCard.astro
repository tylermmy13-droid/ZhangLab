---
// ─── Lightweight student card — no photo, no detail page link ───
import type { StudentMember } from '../data/students';

const { student, accent } = Astro.props as {
  student: StudentMember;
  accent: string;
};

// Extract initials from the Chinese name
const initial = student.nameZh.charAt(0);
const enName = student.name.split('/')[1]?.trim() || '';
---
<div class="student-card" style={`--card-accent: ${accent}`}>
  {/* Initials avatar — no photo */}
  <div class="student-card-avatar">
    <span class="student-card-initial">{initial}</span>
  </div>
  <div class="student-card-info">
    <p class="student-card-name">{student.nameZh}</p>
    <p class="student-card-name-en">{enName}</p>
    <span class="student-card-role" style={`background: ${accent}18; color: ${accent}`}>
      <span data-en={student.type === 'phd' ? 'Ph.D.' : student.type === 'academic-master' ? 'M.Sc.' : 'M.Sc.'}
            data-zh={student.type === 'phd' ? '博士' : student.type === 'academic-master' ? '学硕' : '专硕'}>
        {student.type === 'phd' ? '博士' : student.type === 'academic-master' ? '学硕' : '专硕'}
      </span>
    </span>
    <p class="student-card-enrollment">
      <span data-en={`Enrolled: ${student.enrollmentYear}`}
            data-zh={`${student.enrollmentYear}年入学`}>
        {student.enrollmentYear}年入学
      </span>
    </p>
  </div>
</div>

<style>
  /* ─── Student Card — compact, lighter than member cards ─── */
  .student-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    border-radius: 16px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    text-decoration: none;
    transition: all 0.3s ease;
    flex-shrink: 0;
    width: 100%;
    cursor: default;
  }
  .student-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: var(--card-accent, #b0aea5);
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
  }

  /* ─── Avatar (initials only) ─── */
  .student-card-avatar {
    width: 100%;
    aspect-ratio: 1 / 0.75;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.03);
  }

  .student-card-initial {
    font-size: 40px;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.2);
    font-family: "Inter", sans-serif;
    user-select: none;
  }

  /* ─── Info area ─── */
  .student-card-info {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 14px 12px 18px;
    gap: 4px;
    width: 100%;
  }

  .student-card-name {
    margin: 0;
    color: #faf9f5;
    font-weight: 600;
    font-size: 20px;              /* enlarged from 16px */
    line-height: 1.3;
  }

  .student-card-name-en {
    margin: 0;
    color: rgba(255, 255, 255, 0.35);
    font-size: 15px;              /* enlarged from 12px */
    font-weight: 400;
  }

  /* ─── Role badge ─── */
  .student-card-role {
    display: inline-block;
    margin-top: 4px;
    padding: 3px 14px;
    border-radius: 20px;
    font-size: 15px;             /* slightly larger than 13px */
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  /* ─── Enrollment text ─── */
  .student-card-enrollment {
    margin: 2px 0 0;
    color: rgba(255, 255, 255, 0.3);
    font-size: 11px;
  }
</style>
