---
import type { StudentMember } from '../data/students';

const { student, accent } = Astro.props as {
  student: StudentMember;
  accent: string;
};

const initial = student.nameZh.charAt(0);
const enName = student.name.split('/')[1]?.trim() || '';
---
<!-- ===== 学生卡片组件 ===== -->
<div class="student-card" style={`--card-accent: ${accent}`}>
  <div class="student-card-avatar">
    <span class="student-card-initial">{initial}</span>
  </div>
  <div class="student-card-info">
    <p class="student-card-name">{student.nameZh}</p>
    <p class="student-card-name-en">{enName}</p>
    <span class="student-card-role" style={`background: ${accent}18`}>
      <span>
        {student.type === 'phd' ? 'Ph.D.' : student.type === 'academic-master' ? 'M.A.Sc.' : 'M.Eng.'}
      </span>
    </span>
    <p class="student-card-enrollment">
      <span>Enrolled {student.enrollmentYear}</span>
    </p>
  </div>
</div>

<style>
  .student-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    max-width: 220px;
    box-sizing: border-box;
    border-radius: 12px;
    overflow: hidden;
    background: #e4dbcd;
    border: 1px solid rgba(20, 20, 19, 0.06);
    text-decoration: none;
    transition: all 0.3s ease;
    flex-shrink: 0;
    cursor: default;
  }
  .student-card:hover {
    background: #f4e5c7;
    border-color: var(--card-accent, #b0aea5);
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(20, 20, 19, 0.08);
  }
  .student-card-avatar {
    width: 100%;
    aspect-ratio: 1 / 0.65;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #e8e6dc;
  }
  .student-card-initial {
    font-size: 32px;
    font-weight: 600;
    color: rgba(20, 20, 19, 0.15);
    font-family: "Inter", sans-serif;
    user-select: none;
  }
  .student-card-info {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 10px 8px 14px;
    gap: 3px;
    width: 100%;
  }
  .student-card-name {
    margin: 0;
    color: #141413;
    font-weight: 600;
    font-size: 16px;
    line-height: 1.3;
  }
  .student-card-name-en {
    margin: 0;
    color: #141413;
    font-size: 12px;
    font-weight: 400;
  }
  .student-card-role {
    display: inline-block;
    margin-top: 4px;
    padding: 2px 10px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: #141413 !important;
  }
  .student-card-enrollment {
    margin: 2px 0 0;
    color: #141413;
    font-size: 10px;
  }
</style>
