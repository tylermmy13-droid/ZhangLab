<div class="lang-switch" id="langSwitch" data-active="zh" role="radiogroup" aria-label="语言切换 / Language Switch">
  <span class="lang-option" data-lang="en">EN</span>
  <span class="lang-option active" data-lang="zh">中文</span>
  <div class="lang-slider"></div>
</div>

<style>
  .lang-switch {
    position: relative;
    display: flex;
    align-items: center;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(20, 20, 19, 0.1);
    border-radius: 999px;
    padding: 3px;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    z-index: 1;
    flex-shrink: 0;
  }
  .lang-option {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 6px 14px;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 560;
    letter-spacing: 0.01em;
    color: #b0aea5;
    cursor: pointer;
    transition: color 0.3s ease;
    user-select: none;
    min-width: 52px;
    text-align: center;
  }
  .lang-option.active {
    color: #141413;
    pointer-events: none;
  }
  .lang-slider {
    position: absolute;
    top: 3px;
    left: 3px;
    width: calc(50% - 3px);
    height: calc(100% - 6px);
    background: rgba(255, 255, 255, 0.85);
    border-radius: 999px;
    box-shadow: 0 1px 4px rgba(20, 20, 19, 0.08);
    transition: transform 0.28s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .lang-switch[data-active="zh"] .lang-slider {
    transform: translateX(100%);
  }
</style>
