<div class="lang-switch" id="langSwitch" data-active="zh" role="radiogroup" aria-label="语言切换 / Language Switch">
  <span class="lang-option active" data-lang="zh">中文</span>
  <span class="lang-option" data-lang="en">EN</span>
  <div class="lang-slider"></div>
</div>

<style>
  .lang-switch {
    position: relative;
    display: flex;
    align-items: center;
    background: rgba(242, 240, 233, 0.7);
    border: 1px solid rgba(30, 31, 30, 0.10);
    border-radius: 999px;
    padding: 5px;
    backdrop-filter: blur(24px) saturate(1.22);
    -webkit-backdrop-filter: blur(24px) saturate(1.22);
    box-shadow: 0 18px 56px rgba(30, 31, 30, 0.10), inset 0 1px 0 rgba(255, 255, 255, 0.6);
    z-index: 1;
    flex-shrink: 0;
  }
  .lang-option {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 20px;
    border-radius: 999px;
    font-size: 16px;
    font-weight: 520;
    letter-spacing: -0.015em;
    color: rgba(30, 31, 30, 0.86);
    cursor: pointer;
    transition: color 0.3s ease;
    user-select: none;
    min-width: 68px;
    text-align: center;
  }
  .lang-option.active {
    color: rgba(30, 31, 30, 0.86);
    pointer-events: none;
  }
  .lang-slider {
    position: absolute;
    top: 5px;
    left: 5px;
    width: calc(50% - 5px);
    height: calc(100% - 10px);
    background: rgba(30, 31, 30, 0.08);
    border-radius: 999px;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08), 0 10px 24px rgba(0, 0, 0, 0.06);
    transition: transform 0.32s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .lang-switch[data-active="en"] .lang-slider {
    transform: translateX(100%);
  }
</style>
