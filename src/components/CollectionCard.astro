---
const { item } = Astro.props;
const href = `/collections/${item.id}/`;
const pubDate = item.data.pubDate.toISOString().split('T')[0];
const accentColor = item.data.accentColor || '#6a9bcc';
---
<!-- ===== 研究方向卡片组件（支持中英文） ===== -->
<a class="card collection-card" href={href} data-accent={accentColor}>
  <span class="card-media">
    <img class="card-image" src={item.data.image} alt="" loading="lazy" />
  </span>
  <div class="collection-card-body">
    <span class="tag-pill collection-tag" data-en={item.data.platform} data-zh={item.data.platformZh}>{item.data.platform}</span>
    <h3 class="collection-card-title" data-en={item.data.title} data-zh={item.data.titleZh}>{item.data.title}</h3>
    <p data-en={item.data.description} data-zh={item.data.descriptionZh}>{item.data.description}</p>
    <span class="card-meta">{pubDate}</span>
  </div>
</a>

<style>
  .collection-card {
    text-decoration: none;
    display: block;
    border-radius: 16px;
    overflow: hidden;
    background: #e4dbcd;
    transition: all 0.35s cubic-bezier(.16, .84, .24, 1);
    cursor: pointer;
    position: relative;
  }
  .collection-card:hover {
    background: #f4e5c7;
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(30, 31, 30, 0.12);
  }
  .collection-card :global(.card-media) {
    margin: 0;
    border-radius: 0;
    position: relative;
  }
  .collection-card :global(.card-media)::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 40%, rgba(30,31,30,0.15) 100%);
    pointer-events: none;
  }
  .collection-card :global(.card-image) {
    transition: transform 0.5s cubic-bezier(.16, .84, .24, 1);
  }
  .collection-card:hover :global(.card-image) {
    transform: scale(1.05);
  }
  .collection-card-body {
    padding: 20px 24px 26px;
  }
  .collection-card :global(.collection-tag) {
    background: rgba(106, 155, 204, 0.12);
    color: #6a9bcc;
    border: 1px solid rgba(106, 155, 204, 0.15);
    margin: 0 0 14px;
  }
  .collection-card[data-accent="#d97757"] :global(.collection-tag) {
    background: rgba(217, 119, 87, 0.12);
    color: #d97757;
    border-color: rgba(217, 119, 87, 0.15);
  }
  .collection-card[data-accent="#788c5d"] :global(.collection-tag) {
    background: rgba(120, 140, 93, 0.12);
    color: #788c5d;
    border-color: rgba(120, 140, 93, 0.15);
  }
  .collection-card[data-accent="#b0a07a"] :global(.collection-tag) {
    background: rgba(176, 160, 122, 0.12);
    color: #9a8a60;
    border-color: rgba(176, 160, 122, 0.15);
  }
  .collection-card[data-accent="#8b7ab0"] :global(.collection-tag) {
    background: rgba(139, 122, 176, 0.12);
    color: #8b7ab0;
    border-color: rgba(139, 122, 176, 0.15);
  }
  .collection-card :global(h3) {
    font-family: var(--font-title);
    font-weight: 400;
    font-size: clamp(18px, 1.5vw, 23px);
    line-height: 1.3;
    letter-spacing: -0.02em;
    color: #141413;
    margin: 0 0 12px;
  }
  .collection-card :global(.card-meta) {
    color: #b0aea5;
    font-size: 12px;
    margin-top: 8px;
  }
  .collection-card :global(p) {
    color: #171715;
    font-size: 14px;
    line-height: 1.55;
    margin: 0 0 10px;
  }
</style>
