---
const { item } = Astro.props;
const tag = item.data.category ?? item.data.tags?.[0] ?? 'Blog';
const href = `/blogs/${item.id}/`;
const searchText = [
  item.data.title,
  item.data.description,
  item.data.category,
  ...item.data.tags
].join(' ').toLowerCase();
const filterText = [item.data.category, ...item.data.tags].join('|').toLowerCase();
---
<a class="card" href={href} data-blog-card data-search={searchText} data-filters={filterText}>
  <span class="card-media">
    <img class="card-image" src={item.data.image} alt="" loading="lazy" />
  </span>
  <span class="tag-pill">{tag}</span>
  <h3>{item.data.title}</h3>
  <p>{item.data.description}</p>
  <span class="card-meta">{item.data.category}</span>
</a>
