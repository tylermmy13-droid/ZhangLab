---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact | Zhang Lab" description="Contact Zhang Lab at Xinhua Hospital." headerMode="glass" bodyClass="space-theme">
  <main class="contact-page">
    <section class="contact-hero">
      <div class="container contact-hero-inner">
        <h1 class="contact-title" data-en="Contact Us" data-zh="联系我们">Contact Us</h1>
        <p class="contact-lede" data-en="For clinical research collaboration, student inquiries, or translational partnership, reach out to our team." data-zh="临床研究合作、学生培养与转化合作，欢迎联系课题组。">For clinical research collaboration, student inquiries, or translational partnership, reach out to our team.</p>
      </div>
    </section>

    <section class="section contact-section">
      <div class="container contact-list">
        <a class="contact-pill" href="mailto:li.zhang@shsmu.edu.cn" aria-label="Email li.zhang@shsmu.edu.cn">
          <span class="contact-pill-name">张力 / ZHANG Li</span>
          <span class="contact-pill-email">
            <svg class="contact-pill-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
            li.zhang@shsmu.edu.cn
          </span>
        </a>

        <a class="contact-pill" href="mailto:chenqishan@shsmu.edu.cn" aria-label="Email chenqishan@shsmu.edu.cn">
          <span class="contact-pill-name">陈齐山 / CHEN Qishan</span>
          <span class="contact-pill-email">
            <svg class="contact-pill-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
            chenqishan@shsmu.edu.cn
          </span>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .contact-page { min-height: 70vh; }

  /* ─── Hero ─── */
  .contact-hero {
    padding: 160px 0 48px;
    text-align: center;
  }
  .contact-title {
    margin: 0 0 12px;
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 600;
    color: #faf9f5;
    letter-spacing: -0.02em;
  }
  .contact-lede {
    margin: 0 auto;
    max-width: 560px;
    font-size: clamp(15px, 1.2vw, 18px);
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.6;
  }

  /* ─── Section ─── */
  .contact-section { padding-top: 0; }

  .contact-list {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    max-width: 620px;
    margin: 0 auto;
  }

  /* ─── Pill Card ─── */
  .contact-pill {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    width: 100%;
    padding: 24px 32px 28px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
  }
  .contact-pill:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(217, 119, 87, 0.25);
    box-shadow: 0 8px 32px rgba(217, 119, 87, 0.06);
    transform: translateY(-2px);
  }

  .contact-pill-name {
    font-size: 20px;
    font-weight: 600;
    color: #faf9f5;
    letter-spacing: -0.01em;
  }

  .contact-pill-email {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 6px;
    padding: 8px 20px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.06);
    color: rgba(255, 255, 255, 0.6);
    font-family: "DM Serif Display", Georgia, "Times New Roman", serif;
    font-size: 16px;
    font-weight: 400;
    transition: all 0.2s ease;
  }
  .contact-pill:hover .contact-pill-email {
    background: rgba(217, 119, 87, 0.08);
    border-color: rgba(217, 119, 87, 0.2);
    color: #d97757;
  }

  .contact-pill-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    opacity: 0.5;
    transition: opacity 0.2s;
  }
  .contact-pill:hover .contact-pill-icon {
    opacity: 1;
  }

  /* ─── Responsive ─── */
  @media (max-width: 640px) {
    .contact-hero { padding: 120px 0 32px; }
    .contact-pill { padding: 20px 20px 24px; }
    .contact-pill-name { font-size: 17px; }
    .contact-pill-email { font-size: 14px; padding: 6px 16px; }
  }
</style>
