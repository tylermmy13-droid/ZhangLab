---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { team } from '../../data/team';

export const getStaticPaths = () => {
  return team.map((m) => ({ params: { slug: m.slug } }));
};

const slug = Astro.params.slug;
const member = team.find((m) => m.slug === slug)!;
const pubs = member.publications;
const honors = member.honors;

const getInitials = (name: string) => {
  const parts = name.split('/');
  const zh = parts[0]?.trim() || '';
  if (zh.length >= 2) return zh.slice(0, 1);
  const en = parts[1]?.trim() || '';
  return en.charAt(0).toUpperCase();
};
---
<BaseLayout title={`${member.name} | Zhang Lab`} description={`Zhang Lab profile page of ${member.name}.`} headerMode="glass" bodyClass="space-theme">
  <main class="publication-archive">
    <section class="section member-page">
      <div class="container">
        <a class="member-back" href="/our-team/" data-en="← Back to Our Team" data-zh="← 返回团队">← Back to Our Team</a>

        <div class="member-header">
          <div class="member-photo">
            {member.img ? (
              <img src={member.img} alt={member.nameZh} loading="lazy" />
            ) : (
              <div class="member-photo-initial">{getInitials(member.name)}</div>
            )}
          </div>
          <div class="member-info">
            <h1 class="member-name">{member.name}</h1>
            <p class="member-role" data-en={member.role} data-zh={member.roleZh}>{member.role}</p>
            <p class="member-desc" data-en={member.desc} data-zh={member.descZh}>{member.desc}</p>
            {member.email && (
              <div class="member-social">
                <a class="member-social-link" href={`mailto:${member.email}`} aria-label="Email" title={member.email}>
                  <img src="/assets/icons/gmail.svg" alt="Email" />
                </a>
              </div>
            )}
          </div>
        </div>

        <!-- Publications -->
        {pubs.length > 0 && (
          <div class="member-section">
            <h2 class="member-section-title" data-en="Publications" data-zh="论文">Publications <span class="pub-count">{pubs.length}</span></h2>
            <div class="pub-list">
              {pubs.map((pub) => (
                <div class="pub-item">
                  <div class="pub-thumb">
                    <img src={pub.img} alt={pub.title} loading="lazy" />
                  </div>
                  <div class="pub-info">
                    <p class="pub-title">{pub.title}</p>
                    <p class="pub-authors">{pub.authors}</p>
                    <p class="pub-venue">{pub.venue}</p>
                    <div class="pub-links">
                      {pub.links.map((link) => (
                        <a class="pub-link" href={link.url} target="_blank" rel="noreferrer">{link.label}</a>
                      ))}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- Honors & Awards -->
        {honors.length > 0 && (
          <div class="member-section">
            <h2 class="member-section-title" data-en="Honors &amp; Awards" data-zh="荣誉与奖项">Honors & Awards</h2>
            <ul class="member-list">
              {honors.map((h, i) => <li data-en={h} data-zh={member.honorsZh[i] || h}>{h}</li>)}
            </ul>
          </div>
        )}
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .member-page {
    padding-top: 120px;
    min-height: 80vh;
  }

  .member-back {
    display: inline-block;
    color: rgba(255, 255, 255, 0.5);
    font-size: 14px;
    text-decoration: none;
    margin-bottom: 32px;
    transition: color 0.2s;
  }

  .member-back:hover {
    color: #fff;
  }

  .member-header {
    display: flex;
    gap: 48px;
    align-items: flex-start;
    margin-bottom: 48px;
  }

  .member-photo {
    flex-shrink: 0;
    width: 280px;
    border-radius: 16px;
    overflow: hidden;
    border: 4px solid rgba(255, 255, 255, 0.85);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.3);
    aspect-ratio: 1;
  }

  .member-photo img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .member-photo-initial {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 72px;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.04);
    font-family: "Inter", sans-serif;
    user-select: none;
  }

  .member-info {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding-top: 8px;
    flex: 1;
  }

  .member-name {
    margin: 0;
    color: #fff;
    font-size: clamp(30px, 3.5vw, 44px);
    font-weight: 600;
  }

  .member-role {
    margin: 0;
    color: rgba(255, 255, 255, 0.6);
    font-size: 16px;
  }

  .member-desc {
    margin: 8px 0 0;
    color: rgba(255, 255, 255, 0.45);
    font-size: 15px;
    line-height: 1.7;
    white-space: pre-line;
  }

  .member-social {
    display: flex;
    gap: 14px;
    margin-top: 16px;
  }

  .member-social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: #fff;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .member-social-link:hover {
    transform: scale(1.1);
    box-shadow: 0 4px 16px rgba(255, 255, 255, 0.15);
  }

  .member-social-link img {
    width: 24px;
    height: 24px;
  }

  .member-section {
    margin-bottom: 40px;
    padding-top: 28px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .member-section-title {
    margin: 0 0 24px;
    color: #fff;
    font-size: 22px;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .pub-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 24px;
    height: 24px;
    padding: 0 8px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.7);
    font-size: 13px;
    font-weight: 500;
  }

  .pub-list {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .pub-item {
    display: flex;
    gap: 20px;
    padding: 18px;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.06);
    transition: background 0.2s;
  }

  .pub-item:hover {
    background: rgba(255, 255, 255, 0.08);
  }

  .pub-thumb {
    flex-shrink: 0;
    width: 160px;
    height: 100px;
    border-radius: 8px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.06);
  }

  .pub-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .pub-info {
    display: flex;
    flex-direction: column;
    gap: 6px;
    justify-content: center;
    flex: 1;
  }

  .pub-title {
    margin: 0;
    color: #fff;
    font-size: 16px;
    font-weight: 600;
    line-height: 1.4;
  }

  .pub-authors {
    margin: 0;
    color: rgba(255, 255, 255, 0.5);
    font-size: 13px;
    line-height: 1.5;
  }

  .pub-venue {
    margin: 0;
    color: rgba(255, 255, 255, 0.4);
    font-size: 13px;
  }

  .pub-links {
    display: flex;
    gap: 12px;
    margin-top: 4px;
  }

  .pub-link {
    color: rgba(120, 170, 255, 0.8);
    font-size: 13px;
    text-decoration: none;
    transition: color 0.2s;
  }

  .pub-link:hover {
    color: #fff;
  }

  .member-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .member-list li {
    color: rgba(255, 255, 255, 0.55);
    font-size: 15px;
    line-height: 1.6;
  }

  @media (max-width: 640px) {
    .member-header {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .member-photo {
      width: 220px;
    }
    .member-social {
      justify-content: center;
    }
    .pub-item {
      flex-direction: column;
    }
    .pub-thumb {
      width: 100%;
      height: 160px;
    }
  }
</style>
