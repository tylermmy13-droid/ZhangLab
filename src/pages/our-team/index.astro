---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { team } from '../../data/team';
import { students, studentTypeConfig } from '../../data/students';
import StudentCard from '../../components/StudentCard.astro';

const levels = [1, 2, 3, 4] as const;

// --- Level configuration: each level gets its own accent color and label ---
const levelConfig: Record<number, { label: string; labelZh: string; accent: string }> = {
  1: { label: 'Principal Investigator', labelZh: '课题组长', accent: '#d97757' },
  2: { label: 'Senior Faculty', labelZh: '高级职称', accent: '#6a9bcc' },
  3: { label: 'Attending physcians and Research Staff', labelZh: '主治医师和科研人员', accent: '#788c5d' },
  4: { label: 'Residents', labelZh: '住院和规培医师', accent: '#b0aea5' },
};

// Student groups in display order
const studentGroups: Array<{ type: keyof typeof studentTypeConfig }> = [
  { type: 'phd' },
  { type: 'academic-master' },
  { type: 'professional-master' },
];

// --- Generate initials fallback when no photo is provided ---
const getInitials = (name: string) => {
  const parts = name.split('/');
  const zh = parts[0]?.trim() || '';
  if (zh.length >= 2) return zh.slice(0, 1);
  const en = parts[1]?.trim() || '';
  return en.charAt(0).toUpperCase();
};
---
<BaseLayout title="Team | Zhang Lab" description="Meet the Zhang Lab team." headerMode="glass" bodyClass="space-theme">
  <main class="publication-archive">
    <section class="publication-hero">
      <div class="container publication-hero-inner">
        <h1 class="publication-title" data-en="Our Team" data-zh="团队成员">Our Team</h1>
        <p class="publication-lede" data-en="Meet our dedicated team in clinical and translational research." data-zh="认识我们的团队成员">Meet our dedicated team in clinical and translational research.</p>
      </div>
    </section>

    <section class="section team-section">
      <div class="container">
        <div class="team-tree">
          {levels.map((level) => {
            const members = team.filter((m) => m.level === level);
            const cfg = levelConfig[level];
            if (members.length === 0) return null;

            return (
              <div class="team-level" data-level={level}>
                {/* --- Level label with connector line --- */}
                <div class="level-label-wrap">
                  {level > 1 && <div class="level-connector" style={`background: ${cfg.accent}33`}></div>}
                  <span class="level-label" style={`color: ${cfg.accent}`} data-en={cfg.label} data-zh={cfg.labelZh}>{cfg.label}</span>
                </div>

                {/* --- Member cards grid --- */}
                <div class={`level-cards level-cols-${members.length}`}>
                  {members.map((member) => (
                    <a class="member-card" href={`/our-team/${member.slug}/`} style={`--card-accent: ${cfg.accent}`}>
                      {/* Photo area — spans full width at top, matches card corners */}
                      <div class="member-card-photo">
                        {member.img ? (
                          <img src={member.img} alt={member.nameZh} loading="lazy" />
                        ) : (
                          <span class="member-card-initial">{getInitials(member.name)}</span>
                        )}
                      </div>
                      {/* Text area — name, English name, role badge */}
                      <div class="member-card-info">
                        <p class="member-card-name">{member.nameZh}</p>
                        <p class="member-card-name-en">{member.name.split('/')[1]?.trim()}</p>
                        <span class="member-card-role" style={`background: ${cfg.accent}18; color: ${cfg.accent}`}>{member.roleZh}</span>
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    {/* ═══════════════════════════════════════════
       Current Students section
       ═══════════════════════════════════════════ */}
    <section class="section students-section">
      <div class="container">

        {/* ─── Section title ─── */}
        <div class="students-section-header">
          <h2 class="students-section-title" data-en="Current Students" data-zh="在读学生">Current Students</h2>
        </div>

        {studentGroups.map((group) => {
          const cfg = studentTypeConfig[group.type];
          const groupStudents = students.filter((s) => s.type === group.type);
          if (groupStudents.length === 0) return null;

          return (
            <div class="student-group">
              {/* Group heading */}
              <div class="student-group-label-wrap">
                <span class="student-group-label" style={`color: ${cfg.accent}`}
                      data-en={cfg.labelEn} data-zh={cfg.labelZh}>{cfg.labelZh}</span>
              </div>

              {/* Student cards grid */}
              <div class="student-grid">
                {groupStudents.map((s) => (
                  <StudentCard student={s} accent={cfg.accent} />
                ))}
              </div>
            </div>
          );
        })}
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* ═══════════════════════════════════════════
     Team Tree — vertical connector layout
     ═══════════════════════════════════════════ */
  .team-tree {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    padding-bottom: 80px;
  }

  /* ─── Level section ─── */
  .team-level {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .level-label-wrap {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 28px 0 20px;
    width: 100%;
  }

  /* Vertical line connecting levels */
  .level-connector {
    position: absolute;
    top: 0;
    left: 50%;
    width: 2px;
    height: 28px;
    transform: translateX(-50%);
  }

  .level-label {
    font-family: "DM Serif Display", "Source Han Serif CN Bold", Georgia, "Times New Roman", serif;
    font-size: 26px;
    font-weight: 450;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    opacity: 0.75;
  }

  /* ─── Cards grid ─── */
  .level-cards {
    display: flex;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
    width: 100%;
  }

  /* ═══════════════════════════════════════════
     Member Card — vertical pill/capsule shape
     Photo occupies top ~65%; text at bottom ~35%
     ═══════════════════════════════════════════ */
  .member-card {
    position: relative;
    display: flex;
    flex-direction: column;
    border-radius: 20px;          /* pill-like rounded corners */
    overflow: hidden;             /* clips photo to match card radius */
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.06);
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
    flex-shrink: 0;
  }
  .member-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: var(--card-accent, #6a9bcc);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
  }

  /* ─── Photo area — full width, top portion of the pill ─── */
  .member-card-photo {
    width: 100%;
    aspect-ratio: 1 / 1.1;        /* slightly taller than wide */
    overflow: hidden;
    background: rgba(255, 255, 255, 0.03);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .member-card-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .member-card:hover .member-card-photo img {
    transform: scale(1.07);
  }

  /* ─── Initials fallback (no photo) ─── */
  .member-card-initial {
    font-size: 36px;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.3);
    font-family: "Inter", sans-serif;
    user-select: none;
  }

  /* ─── Text area — bottom portion ─── */
  .member-card-info {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 14px 14px 20px;      /* slightly tighter for 4-col layout */
    gap: 6px;
  }

  .member-card-name {
    margin: 0;
    color: #faf9f5;
    font-weight: 600;
    line-height: 1.3;
  }

  .member-card-name-en {
    margin: 0;
    color: rgba(255, 255, 255, 0.35);
    font-size: 14px;
    font-weight: 400;
  }

  /* ─── Role badge pill — 1.5x larger ─── */
  .member-card-role {
    display: inline-block;
    margin-top: 6px;
    padding: 7px 20px;           /* enlarged from 3px 12px */
    border-radius: 30px;          /* more pill-like */
    font-size: 18px;              /* 11px × 1.5 ≈ 16.5px */
    font-weight: 500;
    letter-spacing: 0.02em;
    line-height: 1.5;
    white-space: pre-line;
  }

  /* ═══════════════════════════════════════════
     Card — uniform size for all levels
     ═══════════════════════════════════════════ */
  .member-card { width: 250px; }           /* ~4 per row */
  .member-card-photo { aspect-ratio: 1 / 0.95; }
  .member-card-name { font-size: 20px; }
  .member-card-initial { font-size: 42px; }

  /* ═══════════════════════════════════════════
     Tablet responsive (max-width: 900px)
     ═══════════════════════════════════════════ */
  @media (max-width: 900px) {
    .level-cards { gap: 14px; }
    .member-card { width: 200px; }
    .member-card-name { font-size: 17px; }
    .member-card-role { font-size: 14px; padding: 4px 14px; }
  }

  /* ═══════════════════════════════════════════
     Mobile responsive (max-width: 640px)
     ═══════════════════════════════════════════ */
  @media (max-width: 640px) {
    .level-cards { gap: 10px; }
    .member-card { width: 160px; }
    .member-card-name { font-size: 15px; }
    .member-card-name-en { font-size: 11px; }
    .member-card-role { font-size: 12px; padding: 3px 10px; }
    .member-card-initial { font-size: 22px !important; }
  }

  /* ═══════════════════════════════════════════
     Current Students section
     ═══════════════════════════════════════════ */
  .students-section {
    padding-top: 0;
  }

  .students-section-header {
    display: flex;
    justify-content: center;
    padding: 40px 0 12px;
  }

  .students-section-title {
    font-family: "DM Serif Display", "Source Han Serif CN Bold", Georgia, "Times New Roman", serif;
    font-size: clamp(36px, 4.5vw, 54px);  /* enlarged from 28-42px */
    font-weight: 400;
    color: #faf9f5;
    letter-spacing: -0.015em;
    margin: 0;
    text-align: center;
  }

  /* ─── Student group ─── */
  .student-group {
    margin-top: 24px;
  }

  .student-group-label-wrap {
    display: flex;
    justify-content: center;
    padding: 16px 0 14px;
  }

  .student-group-label {
    font-family: "DM Serif Display", "Source Han Serif CN Bold", Georgia, "Times New Roman", serif;
    font-size: 26px;               /* 2x original 13px */
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    opacity: 0.75;
  }

  /* ─── Student cards grid — 5 per row, group-centered ─── */
  .student-grid {
    --student-card-width: 200px;
    --student-card-gap: 16px;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--student-card-gap);
    width: 100%;
    max-width: calc((var(--student-card-width) * 5) + (var(--student-card-gap) * 4));
    margin: 0 auto;
  }

  .student-grid :global(.student-card) {
    flex: 0 0 var(--student-card-width);
    max-width: var(--student-card-width);
  }

  /* Tablet */
  @media (max-width: 900px) {
    .student-grid {
      --student-card-width: 160px;
      --student-card-gap: 12px;
      gap: var(--student-card-gap);
    }
  }

  /* Mobile: 2 cols */
  @media (max-width: 640px) {
    .student-grid {
      --student-card-width: calc((100% - var(--student-card-gap)) / 2);
      --student-card-gap: 10px;
      max-width: 430px;
      gap: var(--student-card-gap);
    }

    .student-grid :global(.student-card) {
      min-width: 130px;
    }
  }
</style>
