---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { team } from '../../data/team';

const levels = [1, 2, 3, 4] as const;

const levelConfig: Record<number, { label: string; labelZh: string; accent: string }> = {
  1: { label: 'Principal Investigator', labelZh: '课题组长', accent: '#d97757' },
  2: { label: 'Senior Faculty', labelZh: '高级职称', accent: '#6a9bcc' },
  3: { label: 'Attending physcians and Research Staff', labelZh: '主治医师和科研人员', accent: '#788c5d' },
  4: { label: 'Residents', labelZh: '住院和规培医师', accent: '#b0aea5' },
};

const getInitials = (name: string) => {
  const parts = name.split('/');
  const zh = parts[0]?.trim() || '';
  if (zh.length >= 2) return zh.slice(0, 1);
  const en = parts[1]?.trim() || '';
  return en.charAt(0).toUpperCase();
};
---
<BaseLayout title="Team | Zhang Lab" description="Meet the Zhang Lab team." headerMode="glass" bodyClass="space-theme">
  <main class="publication-archive">
    <section class="publication-hero">
      <div class="container publication-hero-inner">
        <h1 class="publication-title" data-en="Our Team" data-zh="团队成员">Our Team</h1>
        <p class="publication-lede" data-en="Meet our dadicated team in clinical and translational research." data-zh="认识我们的团队成员。">Meet our dadicated team in clinical and translational research.</p>
      </div>
    </section>

    <section class="section team-section">
      <div class="container">
        <div class="team-tree">
          {levels.map((level) => {
            const members = team.filter((m) => m.level === level);
            const cfg = levelConfig[level];
            if (members.length === 0) return null;

            return (
              <div class="team-level" data-level={level}>
                {/* Level label */}
                <div class="level-label-wrap">
                  {level > 1 && <div class="level-connector" style={`background: ${cfg.accent}33`}></div>}
                  <span class="level-label" style={`color: ${cfg.accent}`} data-en={cfg.label} data-zh={cfg.labelZh}>{cfg.label}</span>
                </div>

                {/* Member cards */}
                <div class={`level-cards level-cols-${members.length}`}>
                  {members.map((member) => (
                    <a class="member-card" href={`/our-team/${member.slug}/`} style={`--card-accent: ${cfg.accent}`}>
                      <div class="member-card-avatar">
                        {member.img ? (
                          <img src={member.img} alt={member.nameZh} loading="lazy" />
                        ) : (
                          <span class="member-card-initial">{getInitials(member.name)}</span>
                        )}
                      </div>
                      <div class="member-card-info">
                        <p class="member-card-name">{member.nameZh}</p>
                        <p class="member-card-name-en">{member.name.split('/')[1]?.trim()}</p>
                        <span class="member-card-role" style={`background: ${cfg.accent}18; color: ${cfg.accent}`}>{member.roleZh}</span>
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* ─── Tree Layout ─── */
  .team-tree {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    padding-bottom: 80px;
  }

  /* ─── Level ─── */
  .team-level {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .level-label-wrap {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 28px 0 20px;
    width: 100%;
  }

  .level-connector {
    position: absolute;
    top: 0;
    left: 50%;
    width: 2px;
    height: 28px;
    transform: translateX(-50%);
  }

  .level-label {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    opacity: 0.75;
  }

  /* ─── Cards grid ─── */
  .level-cards {
    display: flex;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
    width: 100%;
  }

  /* ─── Member Card ─── */
  .member-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    padding: 28px 20px 22px;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.06);
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
    flex-shrink: 0;
  }

  .member-card:hover {
    background: rgba(255, 255, 255, 0.07);
    border-color: var(--card-accent, #6a9bcc);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
  }

  /* Card sizes by level */
  [data-level="1"] .member-card {
    width: 280px;
    padding: 36px 24px 28px;
  }
  [data-level="2"] .member-card {
    width: 260px;
    padding: 32px 22px 26px;
  }
  [data-level="3"] .member-card {
    width: 210px;
    padding: 24px 16px 20px;
  }
  [data-level="4"] .member-card {
    width: 200px;
    padding: 22px 14px 18px;
  }

  /* ─── Avatar ─── */
  .member-card-avatar {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid var(--card-accent, rgba(255,255,255,0.2));
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.25);
    flex-shrink: 0;
    transition: border-color 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .member-card:hover .member-card-avatar {
    border-color: var(--card-accent, #6a9bcc);
  }

  .member-card-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  [data-level="1"] .member-card-avatar { width: 140px; height: 140px; }
  [data-level="2"] .member-card-avatar { width: 120px; height: 120px; }
  [data-level="3"] .member-card-avatar { width: 96px; height: 96px; }
  [data-level="4"] .member-card-avatar { width: 88px; height: 88px; }

  /* ─── Initials placeholder (no photo) ─── */
  .member-card-initial {
    font-size: 36px;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.3);
    font-family: "Inter", sans-serif;
    user-select: none;
  }
  [data-level="1"] .member-card-initial { font-size: 42px; }
  [data-level="2"] .member-card-initial { font-size: 36px; }
  [data-level="3"] .member-card-initial { font-size: 30px; }
  [data-level="4"] .member-card-initial { font-size: 28px; }

  /* ─── Card Info ─── */
  .member-card-info {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    text-align: center;
  }

  .member-card-name {
    margin: 0;
    color: #faf9f5;
    font-weight: 600;
    line-height: 1.3;
  }
  [data-level="1"] .member-card-name { font-size: 22px; }
  [data-level="2"] .member-card-name { font-size: 19px; }
  [data-level="3"] .member-card-name { font-size: 16px; }
  [data-level="4"] .member-card-name { font-size: 15px; }

  .member-card-name-en {
    margin: 0;
    color: rgba(255, 255, 255, 0.35);
    font-size: 12px;
    font-weight: 400;
  }

  .member-card-role {
    display: inline-block;
    margin-top: 6px;
    padding: 3px 12px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  /* ─── Responsive ─── */
  @media (max-width: 900px) {
    .level-cards {
      gap: 14px;
    }
    [data-level="1"] .member-card,
    [data-level="2"] .member-card,
    [data-level="3"] .member-card,
    [data-level="4"] .member-card {
      width: 180px;
      padding: 20px 14px 16px;
    }
    [data-level="1"] .member-card-avatar,
    [data-level="2"] .member-card-avatar,
    [data-level="3"] .member-card-avatar,
    [data-level="4"] .member-card-avatar {
      width: 80px;
      height: 80px;
    }
    [data-level="1"] .member-card-name { font-size: 17px; }
    [data-level="2"] .member-card-name,
    [data-level="3"] .member-card-name,
    [data-level="4"] .member-card-name { font-size: 14px; }
  }

  @media (max-width: 640px) {
    .level-cards { gap: 10px; }
    [data-level="1"] .member-card,
    [data-level="2"] .member-card,
    [data-level="3"] .member-card,
    [data-level="4"] .member-card {
      width: 160px;
      padding: 16px 10px 14px;
    }
    [data-level="1"] .member-card-avatar,
    [data-level="2"] .member-card-avatar,
    [data-level="3"] .member-card-avatar,
    [data-level="4"] .member-card-avatar {
      width: 66px;
      height: 66px;
    }
    [data-level="1"] .member-card-name { font-size: 15px; }
    [data-level="2"] .member-card-name,
    [data-level="3"] .member-card-name,
    [data-level="4"] .member-card-name { font-size: 13px; }
    .member-card-name-en { font-size: 11px; }
    .member-card-initial { font-size: 22px !important; }
  }
</style>
