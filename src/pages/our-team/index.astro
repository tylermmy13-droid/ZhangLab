---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { team } from '../../data/team';
import { students, studentTypeConfig } from '../../data/students';
import StudentCard from '../../components/StudentCard.astro';

const levels = [1, 2, 3, 4] as const;

// --- Level configuration: each level gets its own accent color and label ---
const levelConfig: Record<number, { label: string; accent: string }> = {
  1: { label: 'Principal Investigator', accent: '#d97757' },
  2: { label: 'Senior Faculty', accent: '#6a9bcc' },
  3: { label: 'Attending Physicians and Research Staff', accent: '#788c5d' },
  4: { label: 'Residents', accent: '#b0aea5' },
};

// Student groups in display order
const studentGroups: Array<{ type: keyof typeof studentTypeConfig }> = [
  { type: 'phd' },
  { type: 'academic-master' },
  { type: 'professional-master' },
];

// --- Generate initials fallback when no photo is provided ---
const getInitials = (name: string) => {
  const parts = name.split('/');
  const zh = parts[0]?.trim() || '';
  if (zh.length >= 2) return zh.slice(0, 1);
  const en = parts[1]?.trim() || '';
  return en.charAt(0).toUpperCase();
};
---
<!-- ===== 团队成员列表页 ===== -->
<!-- 分层次展示 PI、高级职称、主治医师、住院医师及在培学生 -->
<BaseLayout title="Team | Zhang Lab" description="Meet the Zhang Lab team." headerMode="glass" bodyClass="home-warm">
  <main class="publication-archive">
    <section class="publication-hero">
      <div class="container publication-hero-inner">
        <h1 class="publication-title">Our Team</h1>
        <p class="publication-lede">Meet our dedicated team in clinical and translational research.</p>
      </div>
    </section>

    <section class="section team-section">
      <div class="container">
        <div class="team-tree">
          {levels.map((level) => {
            const members = team.filter((m) => m.level === level);
            const cfg = levelConfig[level];
            if (members.length === 0) return null;

            return (
              <div class="team-level" data-level={level}>
                <div class="level-label-wrap">
                  {level > 1 && <div class="level-connector" style={`background: ${cfg.accent}33`}></div>}
                  <span class="level-label" style={`color: ${cfg.accent}`}>{cfg.label}</span>
                </div>

                <div class={`level-cards level-cols-${members.length}`}>
                  {members.map((member) => (
                    <a class="member-card" href={`/our-team/${member.slug}/`} style={`--card-accent: ${cfg.accent}`} data-slug={member.slug}>
                      <div class="member-card-photo">
                        {member.img ? (
                          <img src={member.img} alt={member.nameZh} loading="lazy" />
                        ) : (
                          <span class="member-card-initial">{getInitials(member.name)}</span>
                        )}
                      </div>
                      <div class="member-card-info">
                        <p class="member-card-name">{member.nameZh}</p>
                        <p class="member-card-name-en">{member.name.split('/')[1]?.trim()}</p>
                        <span class="member-card-role" style={`background: ${cfg.accent}18; color: ${cfg.accent}`}>{member.role}</span>
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- ===== 在培学生 ===== -->
    <section class="section students-section">
      <div class="container">
        <div class="students-section-header">
          <h2 class="students-section-title">Current Students</h2>
        </div>

        {studentGroups.map((group) => {
          const cfg = studentTypeConfig[group.type];
          const groupStudents = students.filter((s) => s.type === group.type);
          if (groupStudents.length === 0) return null;

          return (
            <div class="student-group">
              <div class="student-group-label-wrap">
                <span class="student-group-label" style={`color: ${cfg.accent}`}>{cfg.labelEn}</span>
              </div>
              <div class="student-grid">
                {groupStudents.map((s) => (
                  <StudentCard student={s} accent={cfg.accent} />
                ))}
              </div>
            </div>
          );
        })}
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* ===== 团队层级树 ===== */
  .team-tree {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    padding-bottom: 80px;
  }

  .team-level {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .level-label-wrap {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 28px 0 20px;
    width: 100%;
  }

  .level-connector {
    position: absolute;
    top: 0;
    left: 50%;
    width: 2px;
    height: 28px;
    transform: translateX(-50%);
  }

  .level-label {
    font-family: "DM Serif Display", "Source Han Serif CN Bold", Georgia, "Times New Roman", serif;
    font-size: 26px;
    font-weight: 450;
    letter-spacing: 0.06em;
    opacity: 0.75;
  }

  .level-cards {
    display: flex;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
    width: 100%;
  }

  /* ===== 成员卡片 — 竖版胶囊形状 ===== */
  .member-card {
    position: relative;
    display: flex;
    flex-direction: column;
    border-radius: 20px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.6);
    border: 1px solid rgba(20, 20, 19, 0.06);
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
    flex-shrink: 0;
  }
  .member-card:hover {
    background: rgba(255, 255, 255, 0.8);
    border-color: var(--card-accent, #6a9bcc);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(20, 20, 19, 0.08);
  }

  .member-card-photo {
    width: 100%;
    aspect-ratio: 1 / 1.1;
    overflow: hidden;
    background: #e8e6dc;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .member-card-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .member-card:hover .member-card-photo img {
    transform: scale(1.07);
  }

  .member-card-initial {
    font-size: 36px;
    font-weight: 600;
    color: rgba(20, 20, 19, 0.2);
    font-family: "Inter", sans-serif;
    user-select: none;
  }

  .member-card-info {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 14px 14px 20px;
    gap: 6px;
  }

  .member-card-name {
    margin: 0;
    color: #141413;
    font-weight: 600;
    line-height: 1.3;
  }

  .member-card-name-en {
    margin: 0;
    color: #b0aea5;
    font-size: 14px;
    font-weight: 400;
  }

  .member-card-role {
    display: inline-block;
    margin-top: 6px;
    padding: 7px 20px;
    border-radius: 30px;
    font-size: 18px;
    font-weight: 500;
    letter-spacing: 0.02em;
    line-height: 1.5;
    white-space: pre-line;
  }

  .member-card { width: 250px; }
  .member-card[data-slug="zhang-li"],
  .member-card[data-slug="chen-qishan"] { width: 300px; }
  .member-card-photo { aspect-ratio: 1 / 0.95; }
  .member-card-name { font-size: 20px; }
  .member-card-initial { font-size: 42px; }

  @media (max-width: 900px) {
    .level-cards { gap: 14px; }
    .member-card { width: 200px; }
    .member-card-name { font-size: 17px; }
    .member-card-role { font-size: 14px; padding: 4px 14px; }
  }

  @media (max-width: 640px) {
    .level-cards { gap: 10px; }
    .member-card { width: 160px; }
    .member-card-name { font-size: 15px; }
    .member-card-name-en { font-size: 11px; }
    .member-card-role { font-size: 12px; padding: 3px 10px; }
    .member-card-initial { font-size: 22px !important; }
  }

  /* ===== 在培学生区域 ===== */
  .students-section { padding-top: 0; }

  .students-section-header {
    display: flex;
    justify-content: center;
    padding: 40px 0 12px;
  }

  .students-section-title {
    font-family: "DM Serif Display", "Source Han Serif CN Bold", Georgia, "Times New Roman", serif;
    font-size: clamp(36px, 4.5vw, 54px);
    font-weight: 400;
    color: #141413;
    letter-spacing: -0.015em;
    margin: 0;
    text-align: center;
  }

  .student-group { margin-top: 24px; }

  .student-group-label-wrap {
    display: flex;
    justify-content: center;
    padding: 24px 0 16px;
  }

  .student-group-label {
    font-family: "DM Serif Display", "Source Han Serif CN Bold", Georgia, "Times New Roman", serif;
    font-size: 22px;
    font-weight: 450;
    letter-spacing: 0.04em;
    opacity: 0.75;
  }

  .student-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 12px;
  }

  @media (max-width: 640px) {
    .student-grid { grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 10px; }
  }
</style>
