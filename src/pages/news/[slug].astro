---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const newsItems = (await getCollection('news')).filter((item) => !item.data.draft);
  return newsItems.map((item) => ({ params: { slug: item.id }, props: { item } }));
}

const { item } = Astro.props;
const { Content } = await render(item);
const date = item.data.pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---
<BaseLayout title={`${item.data.title} | News`} description={item.data.description} headerMode="glass" bodyClass="space-theme">
  <main class="collection-detail">
    <section class="detail-hero">
      <div class="container detail-hero-stack">
        <a class="detail-back" href="/news/" data-en="← News" data-zh="← 新闻">← News</a>
        <p class="detail-kicker-pill">{item.data.tags?.[0] ?? 'News'}</p>
        <h1>{item.data.title}</h1>
        <p class="detail-description">{item.data.description}</p>
        <div class="detail-meta">
          <span>{date}</span>
          {item.data.tags.map((tag) => <span>{tag}</span>)}
        </div>
        <div class="detail-cover detail-cover-wide">
          <img src={item.data.image} alt="" loading="lazy" />
        </div>
      </div>
    </section>
    <article class="prose detail-page">
      <Content />
    </article>
  </main>
</BaseLayout>
