---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const newsItems = (await getCollection('news')).filter((item) => !item.data.draft);
  return newsItems.map((item) => ({ params: { slug: item.id }, props: { item } }));
}

const { item } = Astro.props;
const { Content } = await render(item);
const pubDate = item.data.pubDate.toISOString().split('T')[0];
const displayDate = item.data.pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---
<!-- ===== 新闻详情页 ===== -->
<BaseLayout title={`${item.data.title} | News`} description={item.data.description} headerMode="glass" bodyClass="home-warm">
  <main class="publication-archive">
    <section class="publication-hero">
      <div class="container">
        <a class="detail-back" href="/news/" data-en="← News" data-zh="← 新闻">← News</a>
        <span class="tag-pill" style="background:rgba(106,155,204,0.12);color:#6a9bcc;border:1px solid rgba(106,155,204,0.15);margin:0 0 16px;display:inline-flex">{pubDate}</span>
        <h1 class="publication-title" style="text-align:left;max-width:800px">{item.data.title}</h1>
      </div>
    </section>
    <section class="section">
      <div class="prose"><Content /></div>
    </section>
  </main>
</BaseLayout>
