---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="About | Zhang Lab" description="About Zhang Lab." bodyClass="home-warm about-body">
  <main class="about-page" data-about-page>
    <section class="about-story">
      <div class="container about-story-grid">
        <p class="about-label" data-en="About Zhang Lab" data-zh="关于张力课题组">About Zhang Lab</p>
        <div class="about-copy">
          <h1>
            <em data-en="Cardiovascular medicine meets translational engineering." data-zh="心血管医学与转化工程深度融合。">Cardiovascular medicine meets translational engineering.</em>
            <span data-en="We combine clinical cardiology, vascular regeneration, organoid-chip systems, and AI-enabled active health to build new strategies for prevention, diagnosis, therapy, and innovation in cardiovascular disease." data-zh="我们融合临床心脏病学、血管再生修复、类器官芯片系统和人工智能主动健康，构建心血管疾病预防、诊断、治疗和创新的新策略。">We combine clinical cardiology, vascular regeneration, organoid-chip systems, and AI-enabled active health to build new strategies for prevention, diagnosis, therapy, and innovation in cardiovascular disease.</span>
          </h1>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
