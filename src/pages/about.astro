---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<!-- ===== About page ===== -->
<BaseLayout title="About | Zhang Lab" description="Zhang Lab studies vascular injury and repair, myocardial remodeling, cardiovascular multi-organ interactions, and health technologies." bodyClass="home-warm about-body">
  <main class="about-page" data-about-page>
    <section class="about-story">
      <div class="container about-story-grid">
        <p class="about-label" data-en="About Zhang Lab" data-zh="关于张力课题组">About Zhang Lab</p>
        <div class="about-copy">
          <h1>
            <em data-en="Clinical cardiology, vascular biology, and translational research." data-zh="临床心脏病学、血管生物学与转化研究。">Clinical cardiology, vascular biology, and translational research.</em>
            <span data-en="Zhang Lab studies vascular injury and repair, myocardial remodeling, multi-organ interactions in cardiovascular disease, and wearable monitoring and digital health. We combine clinical observation with experimental models, including organoid and organ-on-chip systems, and data analysis to address questions in prevention, diagnosis, and treatment." data-zh="张力课题组围绕血管损伤与修复、心肌重构、心血管多器官互作、可穿戴监测与数字健康开展研究。我们结合临床观察、包括类器官和器官芯片系统在内的实验模型及数据分析，探讨疾病预防、诊断与治疗中的问题。">Zhang Lab studies vascular injury and repair, myocardial remodeling, multi-organ interactions in cardiovascular disease, and wearable monitoring and digital health. We combine clinical observation with experimental models, including organoid and organ-on-chip systems, and data analysis to address questions in prevention, diagnosis, and treatment.</span>
          </h1>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
