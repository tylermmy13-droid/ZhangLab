---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="About | Zhang Lab" description="About Zhang Lab." bodyClass="about-body">
  <main class="about-page" data-about-page>
    <section class="about-story">
      <div class="container about-story-grid">
        <p class="about-label">About Zhang Lab</p>
        <div class="about-copy">
          <h1>
            <em>Cardiovascular medicine meets translational engineering.</em>
            <span>We combine clinical cardiology, vascular regeneration, organoid-chip systems, and AI-enabled active health to build new strategies for prevention, diagnosis, therapy, and innovation in cardiovascular disease.</span>
          </h1>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
