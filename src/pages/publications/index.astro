---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PublicationCard from '../../components/PublicationCard.astro';

const publications = (await getCollection('publications'))
  .filter((item) => !item.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<!-- ===== 论文列表页 ===== -->
<BaseLayout title="Publications | Zhang Lab" description="Our published academic work." headerMode="glass" bodyClass="home-warm">
  <main class="publication-archive">
    <section class="publication-hero">
      <div class="container publication-hero-inner">
        <h1 class="publication-title" data-en="Publications" data-zh="论文发表">Publications</h1>
        <p class="publication-lede" data-en="Peer-reviewed research on vascular regeneration, heart failure, and data-driven cardiovascular medicine." data-zh="血管再生、心力衰竭与数据驱动心血管医学方向的同行评审研究。">Peer-reviewed research on vascular regeneration, heart failure, and data-driven cardiovascular medicine.</p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="card-grid">{publications.map((item) => <PublicationCard item={item} />)}</div>
      </div>
    </section>
  </main>
</BaseLayout>
