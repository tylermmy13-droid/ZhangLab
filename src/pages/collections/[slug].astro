---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const collectionItems = (await getCollection('collections')).filter((item) => !item.data.draft);
  return collectionItems.map((item) => ({ params: { slug: item.id }, props: { item } }));
}

const { item } = Astro.props;
const { Content } = await render(item);
const date = item.data.pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<!-- ===== Research Direction Detail — Warm, editorial, unified ===== -->
<BaseLayout title={`${item.data.title} | Research`} description={item.data.description} headerMode="glass" bodyClass="home-warm">
  <main class="collection-detail">
    <section class="detail-hero">
      <div class="container">
        <a class="detail-back" href="/collections/" data-en="← Research Directions" data-zh="← 研究方向">← Research Directions</a>
        <p class="detail-label" data-en={item.data.platform} data-zh={item.data.platformZh}>{item.data.platform}</p>
        <h1 data-en={item.data.title} data-zh={item.data.titleZh}>{item.data.title}</h1>
        <p class="detail-description" data-en={item.data.description} data-zh={item.data.descriptionZh}>{item.data.description}</p>
        <div class="detail-meta">
          <span>{date}</span>
          <span class="detail-meta-sep">·</span>
          <span>{item.data.tags?.join(' · ') || 'Research'}</span>
        </div>
      </div>
    </section>

    <section class="section detail-cover-section">
      <div class="container">
        <div class="detail-cover">
          <img src={item.data.image} alt="" />
        </div>
      </div>
    </section>

    <section class="section detail-body">
      <div class="container">
        <div class="prose"><Content /></div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .detail-hero {
    padding-top: 150px;
    padding-bottom: 56px;
  }
  .detail-back {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--muted);
    text-decoration: none;
    margin-bottom: 64px;
    transition: color 0.25s ease;
  }
  .detail-back:hover {
    color: var(--ink);
  }
  .detail-label {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: rgba(30, 31, 30, 0.40);
    margin: 0 0 20px;
  }
  .detail-hero h1 {
    font-family: var(--font-title);
    font-size: clamp(40px, 6vw, 72px);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: var(--ink);
    margin: 0 0 24px;
    max-width: 900px;
  }
  .detail-description {
    font-family: var(--font-body);
    font-size: clamp(17px, 1.4vw, 21px);
    line-height: 1.65;
    color: var(--muted);
    max-width: 680px;
    margin: 0 0 20px;
  }
  .detail-meta {
    display: flex;
    gap: 10px;
    align-items: center;
    font-family: var(--font-body);
    font-size: 14px;
    color: rgba(30, 31, 30, 0.40);
  }
  .detail-meta-sep {
    font-size: 14px;
    opacity: 0.5;
  }

  .detail-cover-section {
    padding-top: 0;
    padding-bottom: 80px;
  }
  .detail-cover {
    width: 100%;
    overflow: hidden;
    border-radius: 24px;
    background: var(--blue-2);
  }
  .detail-cover img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 520ms cubic-bezier(.16, .84, .24, 1);
  }
  .detail-cover:hover img {
    transform: scale(1.03);
  }

  .detail-body {
    padding-top: 0;
    padding-bottom: 140px;
  }

  @media (max-width: 720px) {
    .detail-hero {
      padding-top: 110px;
      padding-bottom: 40px;
    }
    .detail-back {
      margin-bottom: 48px;
    }
    .detail-hero h1 {
      font-size: 32px;
      letter-spacing: -0.03em;
    }
    .detail-description {
      font-size: 16px;
    }
    .detail-cover {
      border-radius: 16px;
    }
  }
</style>
