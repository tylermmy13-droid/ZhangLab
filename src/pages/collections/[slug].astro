---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const collectionItems = (await getCollection('collections')).filter((item) => !item.data.draft);
  return collectionItems.map((item) => ({ params: { slug: item.id }, props: { item } }));
}

const { item } = Astro.props;
const { Content } = await render(item);
const date = item.data.pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---
<!-- ===== 研究方向详情页 ===== -->
<BaseLayout title={`${item.data.title} | Collections`} description={item.data.description} headerMode="glass" bodyClass="home-warm">
  <main class="collection-detail">
    <section class="detail-hero">
      <div class="container">
        <a class="detail-back" href="/collections/" data-en="← Collections" data-zh="← 返回">← Collections</a>
        <p class="detail-kicker-pill">{item.data.platform}</p>
        <h1>{item.data.title}</h1>
        <p class="detail-description">{item.data.description}</p>
        <div class="detail-meta">
          <span>{date}</span>
        </div>
        <div class="detail-cover-wide">
          <img src={item.data.image} alt="" />
        </div>
      </div>
    </section>
    <section class="section">
      <div class="prose"><Content /></div>
    </section>
  </main>
</BaseLayout>
