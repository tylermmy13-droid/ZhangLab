---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const collectionItems = (await getCollection('collections'))
  .filter((item) => !item.data.draft)
  .sort((a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf());
---

<!-- ===== Research Areas — Warm editorial cards, unified with site ===== -->
<BaseLayout title="Research Areas | Zhang Lab" description="Five research areas in cardiovascular medicine." headerMode="glass" bodyClass="home-warm">
  <main class="collection-archive">
    <section class="collection-hero">
      <div class="container collection-hero-inner">
        <h1 class="collection-title" data-en="Research <em>Areas</em>" data-zh="研究<em>方向</em>">Research <em>Areas</em></h1>
        <p class="collection-lede" data-en="We investigate five research areas in cardiovascular medicine: vascular biology, cardiac repair, multi-organ interactions, wearable monitoring, and data-driven research." data-zh="我们围绕五个心血管医学研究领域开展工作：血管生物学、心肌修复、多器官互作、可穿戴监测及数据驱动研究。">We investigate five research areas in cardiovascular medicine: vascular biology, cardiac repair, multi-organ interactions, wearable monitoring, and data-driven research.</p>
      </div>
    </section>

    <section class="section directions-section">
      <div class="container">
        <div class="directions-grid">
          {collectionItems.map((item, index) => {
            const num = String(index + 1).padStart(2, '0');
            return (
              <a class="direction-card" href={`/collections/${item.id}/`}>
                <div class="direction-card-media">
                  <img src={item.data.image} alt="" loading="lazy" />
                  <span class="direction-card-number" aria-hidden="true">{num}</span>
                </div>
                <div class="direction-card-body">
                  <span class="direction-card-label" data-en={item.data.platform} data-zh={item.data.platformZh}>{item.data.platform}</span>
                  <h2 class="direction-card-title" data-en={item.data.title} data-zh={item.data.titleZh}>{item.data.title}</h2>
                  <p class="direction-card-desc" data-en={item.data.description} data-zh={item.data.descriptionZh}>{item.data.description}</p>
                  <span class="direction-card-arrow" aria-hidden="true">→</span>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* ===== Hero — Bold, warm, editorial ===== */
  .collection-hero {
    padding: 140px 0 64px;
  }
  .collection-title {
    font-family: var(--font-title);
    font-size: clamp(48px, 8vw, 96px);
    font-weight: 400;
    line-height: 1.0;
    letter-spacing: -0.04em;
    color: var(--ink);
    margin: 0 0 28px;
    max-width: 900px;
  }
  .collection-title em {
    font-style: normal;
  }
  .collection-lede {
    font-family: var(--font-body);
    font-size: clamp(17px, 1.4vw, 21px);
    line-height: 1.6;
    color: var(--muted);
    max-width: 620px;
    margin: 0;
  }

  /* ===== Direction Cards — Warm, rounded, unified with site ===== */
  .directions-section {
    padding-top: 0;
    padding-bottom: 120px;
  }
  .directions-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  .direction-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    background: #e4dbcd;
    border-radius: 24px;
    overflow: hidden;
    transition: background 0.45s ease, transform 0.45s cubic-bezier(.16, .84, .24, 1), box-shadow 0.45s ease;
  }
  .direction-card:hover {
    background: #f4e5c7;
    transform: translateY(-6px);
    box-shadow: 0 24px 60px rgba(30, 31, 30, 0.10);
  }

  /* Media area */
  .direction-card-media {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    border-radius: 24px 24px 0 0;
    background: var(--blue-2);
  }
  .direction-card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 520ms cubic-bezier(.16, .84, .24, 1);
  }
  .direction-card:hover .direction-card-media img {
    transform: scale(1.07);
  }

  /* Number badge — large, warm, sits on image */
  .direction-card-number {
    position: absolute;
    top: 20px;
    left: 20px;
    font-family: "DM Serif Display", Georgia, "Times New Roman", serif;
    font-size: 56px;
    font-weight: 400;
    line-height: 1;
    color: rgba(255, 255, 255, 0.85);
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.25);
    letter-spacing: -0.02em;
    transition: color 0.3s ease, transform 0.3s ease;
  }
  .direction-card:hover .direction-card-number {
    color: #fff;
    transform: scale(1.05);
  }

  /* Card body */
  .direction-card-body {
    padding: 28px 28px 32px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .direction-card-label {
    display: block;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: rgba(30, 31, 30, 0.42);
    margin-bottom: 12px;
  }
  .direction-card-title {
    font-family: var(--font-title);
    font-size: clamp(22px, 2vw, 30px);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0 0 14px;
  }
  :global(html[lang="en"]) .direction-card-title {
    letter-spacing: 0.01em;
  }
  .direction-card-desc {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.65;
    color: var(--muted);
    margin: 0 0 22px;
    flex: 1;
  }
  .direction-card-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(30, 31, 30, 0.08);
    color: var(--ink);
    font-size: 18px;
    transition: background 0.3s ease, color 0.3s ease, transform 0.3s ease;
  }
  .direction-card:hover .direction-card-arrow {
    background: var(--ink);
    color: #f4e5c7;
    transform: translateX(4px);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .directions-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 720px) {
    .collection-hero {
      padding: 110px 0 48px;
    }
    .collection-title {
      font-size: clamp(36px, 10vw, 52px);
      letter-spacing: -0.03em;
    }
    .directions-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .direction-card-number {
      font-size: 44px;
      top: 16px;
      left: 16px;
    }
    .direction-card-body {
      padding: 22px 22px 26px;
    }
    .direction-card-title {
      font-size: 22px;
    }
  }
</style>
