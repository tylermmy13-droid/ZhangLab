---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import GlobeMap from '../components/GlobeMap.astro';
import NewsCard from '../components/NewsCard.astro';
import PublicationCard from '../components/PublicationCard.astro';
import CollectionCard from '../components/CollectionCard.astro';
import BlogCard from '../components/BlogCard.astro';

const newsItems = (await getCollection('news'))
  .filter((item) => !item.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const publications = (await getCollection('publications'))
  .filter((item) => !item.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const collectionItems = (await getCollection('collections'))
  .filter((item) => !item.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const blogItems = (await getCollection('blogs'))
  .filter((item) => !item.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---
<BaseLayout title="Space Lab" description="Space Lab - Exploring the frontiers of science." headerMode="glass" bodyClass="space-theme">
  <main>
    <GlobeMap />

    <section class="section" id="news">
      <div class="container">
        <div class="section-head">
          <div class="section-head-top">
            <h2 class="section-title" data-en="Latest &lt;em&gt;News&lt;/em&gt;" data-zh="最新&lt;em&gt;新闻&lt;/em&gt;">Latest <em>News</em></h2>
            <a class="button section-cta" href="/news/" data-en="All News" data-zh="全部新闻">All News <span aria-hidden="true">&rarr;</span></a>
          </div>
          <p class="section-copy" data-en="Stay updated with the latest happenings at Space Lab." data-zh="了解 Space Lab 的最新动态。">Stay updated with the latest happenings at Space Lab.</p>
        </div>
        <div class="card-grid">
          {newsItems.map((item) => <NewsCard item={item} />)}
        </div>
      </div>
    </section>

    <section class="section" id="publications">
      <div class="container">
        <div class="section-head">
          <div class="section-head-top">
            <h2 class="section-title" data-en="Latest &lt;em&gt;Publications&lt;/em&gt;" data-zh="最新&lt;em&gt;论文&lt;/em&gt;">Latest <em>Publications</em></h2>
            <a class="button section-cta" href="/publications/" data-en="All Publications" data-zh="全部论文">All Publications <span aria-hidden="true">&rarr;</span></a>
          </div>
          <p class="section-copy" data-en="Research papers accepted by international conferences and journals." data-zh="在国际会议和期刊上发表的研究论文。">Research papers accepted by international conferences and journals.</p>
        </div>
        <div class="card-grid">
          {publications.map((item) => <PublicationCard item={item} />)}
        </div>
      </div>
    </section>

    <section class="section" id="collections">
      <div class="container">
        <div class="section-head">
          <div class="section-head-top">
            <h2 class="section-title" data-en="Latest &lt;em&gt;Collections&lt;/em&gt;" data-zh="最新&lt;em&gt;开源&lt;/em&gt;">Latest <em>Collections</em></h2>
            <a class="button section-cta" href="/collections/" data-en="All Collections" data-zh="全部开源">All Collections <span aria-hidden="true">&rarr;</span></a>
          </div>
          <p class="section-copy" data-en="Projects, datasets, and resources open-sourced on GitHub and Hugging Face." data-zh="在 GitHub 和 Hugging Face 上开源的项目、数据集和资源。">Projects, datasets, and resources open-sourced on GitHub and Hugging Face.</p>
        </div>
        <div class="card-grid">
          {collectionItems.map((item) => <CollectionCard item={item} />)}
        </div>
      </div>
    </section>

    <section class="section" id="blogs">
      <div class="container">
        <div class="section-head">
          <div class="section-head-top">
            <h2 class="section-title" data-en="Latest &lt;em&gt;Blogs&lt;/em&gt;" data-zh="最新&lt;em&gt;博客&lt;/em&gt;">Latest <em>Blogs</em></h2>
            <a class="button section-cta" href="/blogs/" data-en="All Blogs" data-zh="全部博客">All Blogs <span aria-hidden="true">&rarr;</span></a>
          </div>
          <p class="section-copy" data-en="Notes on research, technology, and scientific exploration." data-zh="关于研究、技术和科学探索的笔记。">Notes on research, technology, and scientific exploration.</p>
        </div>
        <div class="card-grid">
          {blogItems.map((item) => <BlogCard item={item} />)}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
