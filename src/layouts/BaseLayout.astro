---
import '../styles/global.css';
import LangSwitch from '../components/LangSwitch.astro';
import StarsCanvas from '../components/StarsCanvas.astro';

const {
  title = 'Zhang Lab',
  description = 'Zhang Lab at Xinhua Hospital, Shanghai Jiao Tong University School of Medicine.',
  headerMode = 'auto',
  bodyClass = ''
} = Astro.props;

const isSpaceTheme = bodyClass.includes('space-theme');
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- DNS prefetch & preconnect for Google Fonts (CJK subset delivery) -->
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Google Fonts: Noto Sans SC (body) — Chinese subset -->
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <!-- Preload critical fonts -->
    <link rel="preload" href="/assets/fonts/dm-serif-display-latin-400-normal.ttf" as="font" type="font/ttf" crossorigin />
    <link rel="preload" href="/assets/fonts/SourceHanSerifCN-Bold.otf" as="font" type="font/otf" crossorigin />

    <script src="/assets/js/i18n.js" defer></script>
  </head>
  <body class={bodyClass}>
    <!-- Skip-to-content for keyboard accessibility -->
    <a class="skip-link" href="#main-content">Skip to main content</a>

    <header class={`site-header ${headerMode === 'glass' ? 'is-visible' : ''}`} data-scroll-header data-header-mode={headerMode}>
      <nav class="nav" aria-label="主导航" role="navigation">
        <a href="/" data-route="home" data-en="Home" data-zh="首页">Home</a>
        <a href="/news/" data-route="news" data-en="News" data-zh="动态">News</a>
        <a href="/collections/" data-route="collections" data-en="Research" data-zh="研究方向">Research</a>
        <a href="/our-team/" data-route="our-team" data-en="Team" data-zh="团队">Team</a>
        <a href="/publications/" data-route="publications" data-en="Publications" data-zh="论文">Publications</a>
        <a href="/contact/" data-route="contact" data-en="Contact" data-zh="联系我们">Contact</a>
      </nav>
    </header>
    {isSpaceTheme && <StarsCanvas />}
    <main id="main-content">
      <slot />
    </main>
    <div class="floating-lang">
      <LangSwitch />
    </div>
    <footer class="footer" role="contentinfo">
      <div class="footer-illustration" aria-hidden="true">
        <img class="footer-illustration-image" src="/assets/footer/footer.png" alt="" loading="lazy" />
      </div>
      <div class="container footer-inner">
        <span>@2026 Zhang Lab</span>
        <span class="footer-note" data-en="Cardiovascular medicine, regeneration, organoids, and AI." data-zh="心血管医学、再生修复、类器官与人工智能。">
          Cardiovascular medicine, regeneration, organoids, and AI.
        </span>
        <span class="footer-credit">
          Template by <a href="https://github.com/choucisan/SpaceLab" target="_blank" rel="noreferrer">SpaceLab</a>
        </span>
      </div>
    </footer>
    <script>
      /* ---- 当前页面 active 胶囊（基于路径段，免疫 base path 改写） ---- */
      const segs = window.location.pathname.split('/').filter(Boolean);
      const pageSeg = segs[0] === 'SpaceLab'
        ? (segs[1] || 'home')
        : (segs[0] || 'home');
      document.querySelectorAll('.nav a').forEach(a => {
        if ((a.dataset.route || '') === pageSeg) a.classList.add('active');
      });

      /* ---- 导航栏：根据背后背景亮度自动切换深/浅文字 ---- */
      const header = document.querySelector('[data-scroll-header]');
      const parseRgb = (value) => {
        const match = value.match(/rgba?\((\d+),\s*(\d+),\s*(\d+)(?:,\s*([\d.]+))?\)/);
        if (!match) return null;
        return {
          r: Number(match[1]),
          g: Number(match[2]),
          b: Number(match[3]),
          a: match[4] === undefined ? 1 : Number(match[4]),
        };
      };

      const backgroundColorAt = (x, y) => {
        if (!header) return null;
        const previousPointerEvents = header.style.pointerEvents;
        header.style.pointerEvents = 'none';
        const elements = document.elementsFromPoint(x, y);
        header.style.pointerEvents = previousPointerEvents;

        for (const element of elements) {
          let current = element;
          while (current && current !== document.documentElement) {
            const color = parseRgb(getComputedStyle(current).backgroundColor);
            if (color && color.a > 0.4) return color;
            current = current.parentElement;
          }
        }

        return parseRgb(getComputedStyle(document.body).backgroundColor);
      };

      const updateNavMode = () => {
        if (!header) return;
        const rect = header.getBoundingClientRect();
        const x = Math.min(window.innerWidth - 1, Math.max(0, rect.left + rect.width / 2));
        const y = Math.min(window.innerHeight - 1, Math.max(0, rect.top + rect.height / 2));
        const color = backgroundColorAt(x, y);
        const luminance = color
          ? (0.2126 * color.r + 0.7152 * color.g + 0.0722 * color.b) / 255
          : 0;
        const isLightBackground = luminance > 0.58;

        header.classList.toggle('on-light', isLightBackground);
        header.classList.toggle('on-dark', !isLightBackground);
      };

      updateNavMode();
      window.addEventListener('scroll', updateNavMode, { passive: true });
      window.addEventListener('resize', updateNavMode);

      /* ---- 原有滚动/header 显示逻辑 ---- */
      const hero = document.querySelector('.hero');
      const clamp = (value, min, max) => Math.min(Math.max(value, min), max);
      const updateScene = () => {
        const fixedGlass = header?.dataset.headerMode === 'glass';
        header?.classList.toggle('is-visible', fixedGlass || window.scrollY > 80);
        if (!hero) return;
        const progress = clamp(window.scrollY / Math.min(hero.clientHeight * 0.34, 420), 0, 1);
        hero.style.setProperty('--hero-cloud-drift-x', `${-progress * Math.min(window.innerWidth * 0.22, 360)}px`);
        hero.style.setProperty('--hero-cloud-drift-y', `${-progress * Math.min(window.innerHeight * 0.18, 150)}px`);
        hero.style.setProperty('--hero-geese-drift-x', `${progress * Math.min(window.innerWidth * 0.16, 260)}px`);
        hero.style.setProperty('--hero-geese-drift-y', `${-progress * Math.min(window.innerHeight * 0.06, 54)}px`);
      };
      updateScene();
      window.addEventListener('scroll', updateScene, { passive: true });
      window.addEventListener('resize', updateScene);
      const revealScenes = document.querySelectorAll('[data-reveal-scene]');
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) entry.target.classList.add('is-visible');
        });
      }, { threshold: 0.28 });
      revealScenes.forEach((scene) => revealObserver.observe(scene));
    </script>
  </body>
</html>
